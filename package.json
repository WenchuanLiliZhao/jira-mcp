{
  "name": "Jira-MCP",
  "version": "1.0.0",
  "description": "Jira-MCP — Jira MCP server for Cursor AI — query Jira projects, issues, and sprints directly from the IDE.",
  "type": "module",
  "main": "mcp/server.js",
  "scripts": {
    "start": "node mcp/server.js",
    "query": "node cli/query.js",
    "done": "node cli/query.js --status Done",
    "todo": "node cli/query.js --status 'To Do'",
    "inprogress": "node cli/query.js --status 'In Progress'",
    "all": "node cli/query.js --status all",
    "help": "node cli/query.js --help",
    "move": "node cli/bulk-move.js",
    "assign": "node cli/bulk-assign.js",
    "set-epic-link": "node cli/set-epic-link.js",
    "set-project-description": "node cli/set-project-description.js",
    "transition": "node cli/bulk-transition.js",
    "sync-links": "node cli/sync-issue-links.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "marked": "^17.0.4",
    "md-to-adf": "^0.6.4"
  },
  "engines": {
    "node": ">=18"
  }
}
